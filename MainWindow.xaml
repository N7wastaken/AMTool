<Window x:Class="AMTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AMTool"
        Width="920"
        Height="392"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Focusable="True"
        WindowStartupLocation="Manual">

    <Grid Background="Transparent">
        <Border Padding="26"
                CornerRadius="30"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0">
            <Grid>
                <Grid x:Name="OrbitScene"
                      Width="780"
                      Height="270"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      PreviewMouseWheel="OrbitScene_PreviewMouseWheel">
                    <Canvas x:Name="ShortcutOrbitLayer"
                            Width="780"
                            Height="270"
                            Background="Transparent"/>

                    <Path Width="286"
                          Height="120"
                          Margin="0,0,0,22"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Bottom"
                          Stretch="Fill"
                          Fill="#FF141A22"
                          Stroke="#55F4F7FB"
                          StrokeThickness="1"
                          IsHitTestVisible="False"
                          Data="M 20 120 C 9 120 0 111 0 100 L 0 46 L 142 0 L 286 46 L 286 100 C 286 111 277 120 266 120 Z"/>

                    <Grid Width="248"
                          Height="52"
                          Margin="0,0,0,42"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Text="AMTool"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <Border x:Name="InfoBadge"
                                Grid.Column="1"
                                Width="34"
                                Height="34"
                                Margin="18,0,0,0"
                                VerticalAlignment="Center"
                                CornerRadius="17"
                                Background="#1EF4F7FB"
                                BorderBrush="#44F4F7FB"
                                BorderThickness="1">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="i"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
